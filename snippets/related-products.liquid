{%- comment -%}
  Auto-suggested related products (replaces metafield-driven list).
  Rules:
    - VENDOR MUST = "Gray Matters" (case-insensitive)
    - At least one of: same product type, same primary/secondary color
      metafield (hex), same first-word title (name)
    - Always render exactly 4 products (vendor-only fallback fills gaps)
    - Skip draft/unpublished products (published_at blank; Liquid has no product.status)
{%- endcomment -%}

{%- assign vendor_norm = product.vendor | downcase | strip -%}
{%- if vendor_norm == 'gray matters' -%}

  {%- assign current_type = product.type | downcase | strip -%}
  {%- assign current_name = product.title | split: ' ' | first | downcase | strip -%}
  {%- assign blank_color = 'ff00bb' -%}

  {%- assign cur_primary_raw = product.metafields.custom.primary_color.value
    | default: product.metafields.custom.primary_color
    | default: ''
  -%}
  {%- assign cur_primary = cur_primary_raw | strip | downcase | remove: '#' -%}
  {%- if cur_primary == blank_color -%}{%- assign cur_primary = '' -%}{%- endif -%}

  {%- assign cur_secondary_raw = product.metafields.custom.secondary_color.value
    | default: product.metafields.custom.secondary_color
    | default: ''
  -%}
  {%- assign cur_secondary = cur_secondary_raw | strip | downcase | remove: '#' -%}
  {%- if cur_secondary == blank_color -%}{%- assign cur_secondary = '' -%}{%- endif -%}

  {%- assign sep = '|' -%}
  {%- assign seen = '|' -%}
  {%- assign type_handles = '' -%}
  {%- assign color_handles = '' -%}
  {%- assign name_handles = '' -%}
  {%- assign vendor_only = '' -%}

  {%- for col in product.collections -%}
    {%- for cand in col.products -%}
      {%- assign tok = cand.handle | append: sep -%}
      {%- assign seen_tok = sep | append: tok -%}

      {%- if cand.id == product.id -%}{%- continue -%}{%- endif -%}
      {%- if seen contains seen_tok -%}{%- continue -%}{%- endif -%}
      {%- if cand.published_at == blank -%}{%- continue -%}{%- endif -%}

      {%- assign cv = cand.vendor | downcase | strip -%}
      {%- if cv != 'gray matters' -%}{%- continue -%}{%- endif -%}

      {%- assign seen = seen | append: tok -%}
      {%- assign vendor_only = vendor_only | append: tok -%}

      {%- assign ct = cand.type | downcase | strip -%}
      {%- if current_type != '' and ct == current_type -%}
        {%- assign type_handles = type_handles | append: tok -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign cp_raw = cand.metafields.custom.primary_color.value
        | default: cand.metafields.custom.primary_color
        | default: ''
      -%}
      {%- assign cp = cp_raw | strip | downcase | remove: '#' -%}
      {%- if cp == blank_color -%}{%- assign cp = '' -%}{%- endif -%}

      {%- assign cs_raw = cand.metafields.custom.secondary_color.value
        | default: cand.metafields.custom.secondary_color
        | default: ''
      -%}
      {%- assign cs = cs_raw | strip | downcase | remove: '#' -%}
      {%- if cs == blank_color -%}{%- assign cs = '' -%}{%- endif -%}

      {%- assign color_match = false -%}
      {%- if cur_primary != '' and cp != '' and cp == cur_primary -%}{%- assign color_match = true -%}{%- endif -%}
      {%- if cur_primary != '' and cs != '' and cs == cur_primary -%}{%- assign color_match = true -%}{%- endif -%}
      {%- if cur_secondary != '' and cp != '' and cp == cur_secondary -%}{%- assign color_match = true -%}{%- endif -%}
      {%- if cur_secondary != '' and cs != '' and cs == cur_secondary -%}{%- assign color_match = true -%}{%- endif -%}
      {%- if color_match -%}
        {%- assign color_handles = color_handles | append: tok -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign cn = cand.title | split: ' ' | first | downcase | strip -%}
      {%- if current_name != '' and cn == current_name -%}
        {%- assign name_handles = name_handles | append: tok -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endfor -%}

  {%- assign target = 4 -%}
  {%- assign final = sep -%}
  {%- assign shown = 0 -%}

  {%- assign type_arr = type_handles | split: sep -%}
  {%- for h in type_arr -%}
    {%- if h == '' -%}{%- continue -%}{%- endif -%}
    {%- if shown >= target -%}{%- break -%}{%- endif -%}
    {%- assign h_tok = sep | append: h | append: sep -%}
    {%- if final contains h_tok -%}{%- continue -%}{%- endif -%}
    {%- assign final = final | append: h | append: sep -%}
    {%- assign shown = shown | plus: 1 -%}
  {%- endfor -%}

  {%- assign color_arr = color_handles | split: sep -%}
  {%- for h in color_arr -%}
    {%- if h == '' -%}{%- continue -%}{%- endif -%}
    {%- if shown >= target -%}{%- break -%}{%- endif -%}
    {%- assign h_tok = sep | append: h | append: sep -%}
    {%- if final contains h_tok -%}{%- continue -%}{%- endif -%}
    {%- assign final = final | append: h | append: sep -%}
    {%- assign shown = shown | plus: 1 -%}
  {%- endfor -%}

  {%- assign name_arr = name_handles | split: sep -%}
  {%- for h in name_arr -%}
    {%- if h == '' -%}{%- continue -%}{%- endif -%}
    {%- if shown >= target -%}{%- break -%}{%- endif -%}
    {%- assign h_tok = sep | append: h | append: sep -%}
    {%- if final contains h_tok -%}{%- continue -%}{%- endif -%}
    {%- assign final = final | append: h | append: sep -%}
    {%- assign shown = shown | plus: 1 -%}
  {%- endfor -%}

  {%- if shown < target -%}
    {%- assign vendor_arr = vendor_only | split: sep -%}
    {%- for h in vendor_arr -%}
      {%- if h == '' -%}{%- continue -%}{%- endif -%}
      {%- if shown >= target -%}{%- break -%}{%- endif -%}
      {%- assign h_tok = sep | append: h | append: sep -%}
      {%- if final contains h_tok -%}{%- continue -%}{%- endif -%}
      {%- assign final = final | append: h | append: sep -%}
      {%- assign shown = shown | plus: 1 -%}
    {%- endfor -%}
  {%- endif -%}

  <div class=''>
    <h3 class='w-full text-center font-accent font-normal text-xl uppercase mb-6'>You may also like</h3>
    <div class='relative w-full pb-6' data-relprod>
      <!-- Viewport -->
      <div class='overflow-hidden md:overflow-visible w-full' data-viewport>
        <!-- Track (flex on mobile, grid on md+) -->
        <div
          class='flex w-full transition-transform duration-300 ease-in-out md:grid md:grid-cols-4 md:gap-0'
          data-track
        >
          {%- assign final_arr = final | split: sep -%}
          {%- for h in final_arr -%}
            {%- if h == '' -%}{%- continue -%}{%- endif -%}
            {%- assign rp = all_products[h] -%}
            {%- if rp != blank and rp.published_at != blank -%}
              <div class='relative group basis-1/2 md:basis-auto shrink-0' data-item>
                <a href='{{ rp.url }}'>
                  {% if rp.featured_image %}
                    <img
                      src='{{ rp.featured_image | image_url: width: 1200 }}'
                      alt='{{ rp.title | escape }}'
                      loading='lazy'
                    >
                  {% endif %}
                  <div
                    class='absolute inset-0 bg-black opacity-0 group-hover:opacity-30 transition-opacity duration-300 ease-in-out'
                  ></div>
                </a>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- Controls (mobile only) -->
      <button
        type='button'
        class='md:hidden absolute left-2 top-1/2 -translate-y-1/2 flex items-center justify-center leading-none'
        aria-label='Previous'
        data-prev
      >
        <i class='fa-solid fa-chevron-left text-white drop-shadow' style='font-size:50px;'></i>
      </button>
      <button
        type='button'
        class='md:hidden absolute right-2 top-1/2 -translate-y-1/2 flex items-center justify-center leading-none'
        aria-label='Next'
        data-next
      >
        <i class='fa-solid fa-chevron-right  text-white drop-shadow' style='font-size:50px;'></i>
      </button>

      <!-- Progress bar -->
      <div
        class='absolute left-2 -bottom-3 h-[2px] w-[100px] bg-gray-300 opacity-0 transition-opacity duration-200'
        data-progress
      ></div>
    </div>
  </div>

{%- endif -%}
