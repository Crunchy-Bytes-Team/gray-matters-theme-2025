{% comment %}
  Renders product variant-picker

  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} Id of the product form to which the variant picker is associated.
  Usage:
  {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
{% endcomment %}
{%- unless product.has_only_default_variant -%}
  {%- liquid
    assign size_requires_selection = false
    if product.selected_variant == blank
      for option in product.options_with_values
        assign option_key_check = option.name | downcase | strip
        if option_key_check contains 'size' or option_key_check contains 'taglia'
          assign size_requires_selection = true
          break
        endif
      endfor
    endif
  -%}
  <variant-selects
    class='w-full'
    id='variant-selects-{{ section.id }}'
    data-section='{{ section.id }}'
    {{ block.shopify_attributes }}
  >
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign swatch_count = option.values | map: 'swatch' | compact | size
        assign picker_type = block.settings.picker_type | default: 'dropdown'
        assign swatch_shape = block.settings.swatch_shape | default: 'none'
        assign option_key = option.name | downcase | strip
        assign is_size_option = false

        if option_key contains 'size' or option_key contains 'taglia'
          assign is_size_option = true
        endif

        assign use_size_placeholder = false
        if is_size_option and size_requires_selection
          assign use_size_placeholder = true
        endif

        if swatch_count > 0 and swatch_shape != 'none'
          if picker_type == 'dropdown'
            assign picker_type = 'swatch_dropdown'
          else
            assign picker_type = 'swatch'
          endif
        endif
      -%}
      {%- if picker_type == 'swatch' -%}
        <fieldset class='js product-form__input product-form__input--swatch'>
          <legend class='form__label'>
            {% if is_size_option %}Size{% else %}{{ option.name }}{% endif %}:
            <span data-selected-value>
              {{- option.selected_value -}}
            </span>
          </legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type,
            swatch_shape: swatch_shape
          %}
        </fieldset>
      {%- elsif picker_type == 'button' -%}
        <fieldset class='js product-form__input product-form__input--pill'>
          <legend class='form__label'>{% if is_size_option %}Size{% else %}{{ option.name }}{% endif %}</legend>
          {% render 'product-variant-options',
            product: product,
            option: option,
            block: block,
            picker_type: picker_type,
            swatch_shape: swatch_shape
          %}
        </fieldset>
      {%- else -%}
        <div class='h-full w-full product-form__input product-form__input--dropdown{% if is_size_option %} product-form__input--dropdown-size{% endif %}'>
          <label class='form__label hidden' for='Option-{{ section.id }}-{{ forloop.index0 }}'>{% if is_size_option %}Size{% else %}{{ option.name }}{% endif %}</label>
          <div class='px-2 h-8 w-full select{% if is_size_option %} select--size{% endif %}'>
            {%- if picker_type == 'swatch_dropdown' -%}
              <span
                data-selected-value
                class='dropdown-swatch'
              >
                {% render 'swatch', swatch: option.selected_value.swatch, shape: swatch_shape %}
              </span>
            {%- endif -%}
            <select
              id='Option-{{ section.id }}-{{ forloop.index0 }}'
              class='variant-select select__select text-15 text-center h-full w-full hover:text-white bg-transparent cursor-pointer transition-colors duration-700 ease-in-out'
              name='options[{{ option.name | escape }}]'
              form='{{ product_form_id }}'
            >
              {%- if is_size_option and size_requires_selection -%}
                <option value='' selected data-size-placeholder>
                  {{- 'products.product.select_size' | t -}}
                </option>
              {%- endif -%}
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: picker_type,
                swatch_shape: swatch_shape,
                use_size_placeholder: use_size_placeholder
              %}
            </select>
            <span class='svg-wrapper hidden'>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <script type='application/json' data-product-variants>
      {{ product.variants | json }}
    </script>
    <script type='application/json' data-selected-variant>
      {%- if size_requires_selection -%}null{%- else -%}{{ product.selected_or_first_available_variant | json }}{%- endif -%}
    </script>
    <script>
      (function() {
        var root = document.getElementById('variant-selects-{{ section.id }}');
        if (!root) return;
        var form = document.getElementById('{{ product_form_id }}');
        if (!form) return;

        // Ensure hidden variant input exists
        var idInput = form.querySelector('input[name="id"]');
        if (!idInput) {
          idInput = document.createElement('input');
          idInput.type = 'hidden';
          idInput.name = 'id';
          idInput.value = '{{ product.selected_or_first_available_variant.id }}';
          form.appendChild(idInput);
        }

        var variantsScript = root.querySelector('script[data-product-variants]');
        var variants = variantsScript
          ? JSON.parse(variantsScript.textContent)
          : [];

        function currentOptions() {
          var selects = root.querySelectorAll('select[name^="options["]');
          return Array.prototype.map.call(selects, function(s) { return s.value; });
        }

        function findVariantByOptions(options) {
          for (var i = 0; i < variants.length; i++) {
            var v = variants[i];
            var match = true;
            for (var j = 0; j < v.options.length; j++) {
              if (String(v.options[j]) !== String(options[j])) { match = false; break; }
            }
            if (match) return v;
          }
          return null;
        }

        function syncVariantFromSelects() {
          var sizeSelect = root.querySelector('.product-form__input--dropdown-size select');
          var productForm = form.closest('product-form');
          var productInfo = root.closest('product-info');

          if (sizeSelect && sizeSelect.value === '') {
            idInput.value = '';
            if (productInfo && productInfo.restorePlaceholderBuyButton) {
              productInfo.restorePlaceholderBuyButton();
            } else {
              var addToCart = form.querySelector('[type="submit"]');
              if (addToCart) {
                addToCart.setAttribute('disabled', 'disabled');
              }
            }
            return;
          }

          var opts = currentOptions();
          var variant = findVariantByOptions(opts);
          if (variant) {
            idInput.value = variant.id;
            if (productForm && productForm.setBuyButtonForVariant) {
              productForm.setBuyButtonForVariant(
                variant,
                sizeSelect ? sizeSelect.value : '',
              );
            }
          }
        }

        root.addEventListener('change', function(e) {
          if (e.target && e.target.matches('select[name^="options["]')) {
            syncVariantFromSelects();
          }
        });

        syncVariantFromSelects();
      })();
    </script>
  </variant-selects>
{%- endunless -%}
