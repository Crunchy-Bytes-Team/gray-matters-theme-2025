<div class='px-6 md:px-20 pt-24 md:pt-40 pb-40 md:pb-56 mb-16 md:mb-24'>
  <div class='max-w-xl mx-auto w-full text-center'>
    <h1 class='text-lg md:text-xl font-bold uppercase tracking-wider mb-2'>
      {{ 'customer.reset_password.title' | t }}
    </h1>
    <p class='text-base text-gray-600 mb-8'>
      {{ 'customer.reset_password.subtext' | t }}
    </p>

    {%- form 'reset_customer_password', class: 'space-y-6 text-left' -%}
      {%- if form.errors -%}
        <div class='mb-2 p-4 bg-red-50 border border-red-200 text-red-700 text-base text-left' role='alert' tabindex='-1'>
          <h2 class='font-semibold mb-2'>{{ 'templates.contact.form.error_heading' | t }}</h2>
          <ul class='list-disc list-inside space-y-1'>
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  <a href='#ResetPassword-{{ field }}' class='underline'>
                    {{ form.errors.translated_fields[field] | capitalize }}
                    {{ form.errors.messages[field] }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div>
        <label for='ResetPassword-password' class='block text-base font-medium mb-2'>
          {{ 'customer.reset_password.password' | t }}
        </label>
        <input
          type='password'
          name='customer[password]'
          id='ResetPassword-password'
          autocomplete='new-password'
          {% if form.errors contains 'password' %}
            aria-invalid='true'
            aria-describedby='ResetPassword-password-error'
          {% endif %}
          class='w-full px-4 py-4 bg-gray-50 focus:outline-none {% if form.errors contains 'password' %}ring-1 ring-red-300{% endif %}'
          placeholder='{{ 'customer.reset_password.password' | t }}'
        >
        {%- if form.errors contains 'password' -%}
          <p id='ResetPassword-password-error' class='mt-2 text-sm text-red-600'>
            {{ form.errors.translated_fields.password | capitalize }}
            {{ form.errors.messages.password }}
          </p>
        {%- endif -%}
      </div>

      <div>
        <label for='ResetPassword-password_confirmation' class='block text-base font-medium mb-2'>
          {{ 'customer.reset_password.password_confirm' | t }}
        </label>
        <input
          type='password'
          name='customer[password_confirmation]'
          id='ResetPassword-password_confirmation'
          autocomplete='new-password'
          {% if form.errors contains 'password_confirmation' %}
            aria-invalid='true'
            aria-describedby='ResetPassword-password_confirmation-error'
          {% endif %}
          class='w-full px-4 py-4 bg-gray-50 focus:outline-none {% if form.errors contains 'password_confirmation' %}ring-1 ring-red-300{% endif %}'
          placeholder='{{ 'customer.reset_password.password_confirm' | t }}'
        >
        {%- if form.errors contains 'password_confirmation' -%}
          <p id='ResetPassword-password_confirmation-error' class='mt-2 text-sm text-red-600'>
            {{ form.errors.translated_fields.password_confirmation | capitalize }}
            {{ form.errors.messages.password_confirmation }}
          </p>
        {%- endif -%}
      </div>

      <div class='flex flex-wrap gap-4 pt-2 justify-center'>
        <button
          type='submit'
          class='bg-black text-white py-3 px-8 uppercase tracking-wider text-base font-semibold hover:opacity-90 transition-opacity'
        >
          {{ 'customer.reset_password.submit' | t }}
        </button>
        <a
          href='{{ routes.account_login_url }}'
          class='bg-white text-black border border-black py-3 px-8 uppercase tracking-wider text-base font-semibold hover:opacity-90 transition-opacity inline-block text-center'
        >
          {{ 'customer.login_page.cancel' | t }}
        </a>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-reset-password.name",
  "settings": []
}
{% endschema %}
