<div class="max-w-7xl mx-auto px-6 md:px-20 py-40">
  <div class="grid grid-cols-1 md:grid-cols-[1fr_3fr] gap-8 md:gap-12 relative">
    <!-- Vertical Separator -->
    <div class="hidden md:block absolute left-[calc(25%-12px)] top-0 bottom-0 w-px bg-gray-200"></div>

    <!-- Left Column: Sidebar -->
    <div class="order-2 md:order-1">
      <!-- ORDER HISTORY -->
      <div class="mb-8">
        <a href="{{ routes.account_url }}" class="text-xl font-bold uppercase tracking-wider hover:opacity-70 transition-opacity">
          {{ 'customer.orders.title' | t }}
        </a>
      </div>

      <!-- ACCOUNT DETAILS -->
      <div class="mb-8">
        <h2 class="text-xl font-bold uppercase tracking-wider mb-4">
          {{ 'customer.account.details' | t }}
        </h2>
        <div class="space-y-2 text-base">
          <p class="font-semibold">{{ customer.name }}</p>
          <p>{{ customer.email }}</p>
          {%- if template.name != 'account_edit' -%}
            <a href="{{ routes.account_edit_url }}" class="underline">
              Edit
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- MY ADDRESSES -->
      <div class="mb-8">
        <h2 class="text-xl font-bold uppercase tracking-wider mb-4">
          {{ 'customer.account.addresses' | t }}
        </h2>
        {%- if customer.default_address -%}
          <div class="mb-4 text-base space-y-1">
            {{ customer.default_address | format_address }}
          </div>
          <div class="space-x-4">
            <a href="{{ routes.account_addresses_url }}" class="underline text-base">
              Edit
            </a>
            <a href="{{ routes.account_addresses_url }}" class="underline text-base">
              Add New Address
            </a>
          </div>
        {%- else -%}
          <a href="{{ routes.account_addresses_url }}" class="underline text-base">
            Add New Address
          </a>
        {%- endif -%}
      </div>

      <!-- MY WISHLIST -->
      <div class="mb-8">
        <h2 class="text-xl font-bold uppercase tracking-wider mb-4">
          {{ 'customer.account.wishlist' | t }}
        </h2>
        <a href="{{ routes.root_url }}/pages/wishlist" class="underline text-base">
          View/Edit Wishlist
        </a>
      </div>

      <!-- Logout -->
      <div class="mb-8">
        <a href="{{ routes.account_logout_url }}" class="underline text-base">
          {{ 'customer.log_out' | t }}
        </a>
      </div>
    </div>

    <!-- Right Column: read-only details + password change via Shopify recover flow -->
    <div class="order-1 md:order-2">
      <div class="md:pl-12">
        <h1 class="text-lg md:text-xl font-bold uppercase tracking-wider mb-6">
          {{ 'customer.account.details' | t }}
        </h1>

        <dl class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10 text-base">
          <div>
            <dt class="font-semibold uppercase tracking-wider text-sm mb-1">{{ 'customer.register.first_name' | t }}</dt>
            <dd>{{ customer.first_name }}</dd>
          </div>
          <div>
            <dt class="font-semibold uppercase tracking-wider text-sm mb-1">{{ 'customer.register.last_name' | t }}</dt>
            <dd>{{ customer.last_name }}</dd>
          </div>
          <div>
            <dt class="font-semibold uppercase tracking-wider text-sm mb-1">{{ 'customer.login_page.email' | t }}</dt>
            <dd>{{ customer.email }}</dd>
          </div>
          <div>
            <dt class="font-semibold uppercase tracking-wider text-sm mb-1">Shoe Size</dt>
            <dd>{{ customer.note | default: '—' }}</dd>
          </div>
        </dl>

        {%- comment -%}
          Password: use {% form 'recover_customer_password' %} (POST /account/recover). Shopify emails a link;
          the customer sets a new password on the reset_password template ({% form 'reset_customer_password' %}).
          Inline password + POST /account is not a supported profile update on legacy Liquid storefronts.
        {%- endcomment -%}
        <div class="border-t border-gray-200 pt-10">
          <h2 class="text-base font-bold uppercase tracking-wider mb-2">
            {{ 'customer.recover_password.title' | t }}
          </h2>
          <p class="text-base text-gray-600 mb-6 max-w-xl">
            {{ 'customer.recover_password.subtext' | t }}
          </p>

          {%- form 'recover_customer_password', class: 'account-recover-password-form', return_to: routes.account_edit_url -%}
            {%- if form.posted_successfully? -%}
              <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 text-base" role="status">
                {{ 'customer.recover_password.success' | t }}
              </div>
            {%- endif -%}
            {%- if form.errors -%}
              <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 text-base">
                <p>{{ form.errors.messages.form }}</p>
              </div>
            {%- endif -%}

            <input type="hidden" name="email" value="{{ customer.email | escape }}">

            <div class="flex flex-wrap gap-4 mt-6">
              <button
                type="submit"
                class="bg-black text-white py-3 px-8 uppercase tracking-wider text-base font-semibold hover:opacity-90 transition-opacity"
              >
                {{ 'customer.login_page.submit' | t }}
              </button>
              <a
                href="{{ routes.account_url }}"
                class="bg-white text-black border border-black py-3 px-8 uppercase tracking-wider text-base font-semibold hover:opacity-90 transition-opacity inline-block text-center"
              >
                {{ 'customer.account.return' | t }}
              </a>
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account-edit.name",
  "settings": []
}
{% endschema %}

